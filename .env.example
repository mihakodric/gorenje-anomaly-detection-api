# Database Configuration
# PostgreSQL connection string for async SQLAlchemy
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/anomaly_detection

# Failure Detection Thresholds
# Number of past cycles to consider for failure detection
WINDOW_SIZE=10

# Minimum number of anomalies required in the window to flag failure (threshold strategy)
THRESHOLD_COUNT=8

# Number of consecutive anomalies required to flag failure (consecutive strategy)
CONSECUTIVE_THRESHOLD=3

# Whether to use consecutive strategy (true) or threshold strategy (false)
REQUIRE_CONSECUTIVE=false

# Model Residual Limits (optional)
# If not set, defaults to mean + 2*std from training data
HEATER_LIMIT=150
PUMP_LIMIT=100
MOTOR_LIMIT=2

# Component Display Colors
# Used in response.components.*.color and wm_svg rendering
COMPONENT_OK_COLOR=#669900
COMPONENT_WARNING_COLOR=#FFCC00
COMPONENT_FAILING_COLOR=#CC0000

# API Configuration
API_TITLE=Washing Machine Anomaly Detection API
API_VERSION=1.0.0
API_DESCRIPTION=Production-ready FastAPI service for ML-based anomaly detection and failure prediction

# CORS Settings
# Comma-separated list of allowed origins (use * for all)
CORS_ORIGINS=*

# Logging
LOG_LEVEL=INFO
